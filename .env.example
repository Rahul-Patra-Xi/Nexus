# Supabase Configuration
# Get these values from: https://supabase.com/dashboard/project/[YOUR_PROJECT]/settings/api

# Your Supabase project URL
VITE_SUPABASE_URL=https://xxxxxx.supabase.co

# Supabase anon (public) key - Copy from "anon public" key (NOT the service_role key)
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxx

# Alternative: You can use VITE_SUPABASE_PUBLISHABLE_KEY instead
# VITE_SUPABASE_PUBLISHABLE_KEY=xxxxx
